pipeline {
    agent any

    tools {
        jdk 'jdk21'
        gradle 'gradle-8'
    }

    environment {
        DOCKER_HUB_USERNAME = 'octavian2508'
        DOCKER_PASSWORD = credentials('docker_password')
        GITHUB_TOKEN = credentials('github_token')
    }

    stages {
        stage('Build') {
            steps {
                sh './gradlew clean build'
            }
        }

        stage('Test') {
            steps {
                sh './gradlew test'
            }
        }

        stage('Version & Tag') {
            steps {
                script {
                    sh 'git fetch --tags'
                    def latestTag = sh(
                        script: 'git tag | sort -V | tail -1',
                        returnStdout: true
                    ).trim()

                    if (!latestTag) {
                        latestTag = '1.0.0'
                    }

                    def parts = latestTag.tokenize('.')
                    if (parts.size() != 3) {
                        error("Latest tag '${latestTag}' is not in MAJOR.MINOR.PATCH format")
                    }

                    env.MAJOR_VERSION = parts[0]
                    env.MINOR_VERSION = parts[1]
                    env.PATCH_VERSION = parts[2]

                    def minorInt = env.MINOR_VERSION.toInteger()
                    env.IMAGE_TAG = "${env.MAJOR_VERSION}.${minorInt + 1}.${env.PATCH_VERSION}"
                    echo "Building version: ${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_HUB_USERNAME/prod-eng-img:$IMAGE_TAG .'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKER_PASSWORD_PSW | docker login -u $DOCKER_HUB_USERNAME --password-stdin
                    docker push $DOCKER_HUB_USERNAME/prod-eng-img:$IMAGE_TAG
                '''
            }
        }

        stage('Deploy Application') {
            steps {
                script {
                    sh '''
                        docker ps -q --filter "name=prod-eng" | xargs -r docker stop
                        docker ps -q --filter "name=mongo" | xargs -r docker stop
                    '''
                    sh """
                        DOCKER_HUB_USERNAME=${DOCKER_HUB_USERNAME} IMAGE_TAG=${env.IMAGE_TAG} docker compose up -d prod-eng mongo
                    """
                    sleep 30
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'MONGODB_CONECTION_URL=mongodb://root:example@host.docker.internal:27017 ./gradlew testIT'
            }
        }

        stage('Tag Release') {
            steps {
                sh '''
                    git fetch --tags
                    if ! git rev-parse "$IMAGE_TAG" >/dev/null 2>&1; then
                      git tag $IMAGE_TAG
                    fi
                    git push https://$GITHUB_TOKEN_PSW@github.com/mateigabriela/production-eng.git $IMAGE_TAG
                '''
            }
        }
    }

    post {
        always {
            junit '**/build/test-results/**/*.xml'
            publishHTML([
                allowMissing: true,
                alwaysLinkToLastBuild: false,
                keepAll: true,
                reportDir: 'build/reports/tests/test',
                reportFiles: 'index.html',
                reportName: 'Test Report'
            ])
            sh 'docker logout'
        }
    }
}